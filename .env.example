# Copy this file to .env and populate with your secrets.

# Next Auth — generate with: npx auth secret
AUTH_SECRET=""

NODE_ENV="development"

# Optional Discord OAuth (bonus provider)
AUTH_DISCORD_ID=""
AUTH_DISCORD_SECRET=""

# Prisma / Supabase PostgreSQL
# DATABASE_URL: transaction pooler (port 6543) for app runtime
# DIRECT_URL: session pooler or direct connection (port 5432) for migrations
DATABASE_URL="postgresql://postgres:password@localhost:5432/articledesk"
DIRECT_URL="postgresql://postgres:password@localhost:5432/articledesk"
